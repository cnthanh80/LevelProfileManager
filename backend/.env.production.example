APP_NAME=Level Profile Manager
APP_ENV=production
APP_VERSION=2.2.0
DEBUG=false
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://lpm_user:change_me_in_production@postgres:5432/level_profile_db
JWT_SECRET_KEY=change_this_to_a_long_random_secret_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
FILE_STORAGE_PATH=/app/storage/uploads
CORS_ALLOWED_ORIGINS=https://lpm.example.gov.vn
SECURITY_HEADERS_ENABLED=true
REQUEST_ID_HEADER=X-Request-ID
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_EXCLUDE_PATHS=/api/v1/health,/docs,/openapi.json
NOTIFICATION_DRY_RUN=false
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.gov.vn
SMTP_FROM_NAME=Level Profile Manager
SMTP_USE_TLS=true
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
LDAP_ENABLED=false
LDAP_DRY_RUN=false
LDAP_SERVER_URI=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_BASE_DN=
LDAP_USER_FILTER=(sAMAccountName={username})
SSO_ENABLED=false
SSO_PROVIDER_NAME=Internal SSO
ACCESS_CONTROL_STRICT_ORG_SCOPE=true
